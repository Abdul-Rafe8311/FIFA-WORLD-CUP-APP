# ---- Database (Supabase Postgres, POOLED "Transaction" mode, port 6543) ----
# Required for Vercel serverless. In Supabase: Project Settings > Database >
# Connection string > "Transaction" pooler. Append ?sslmode=require.
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-xx.pooler.supabase.com:6543/postgres?sslmode=require"

# ---- Auth.js / NextAuth ----
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"
AUTH_GOOGLE_ID="your-google-oauth-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# ---- Groq (AI Pundit) ----
GROQ_API_KEY="gsk_xxx"

# ---- football-data.org (fixtures / results) ----
FOOTBALL_DATA_TOKEN="your-football-data-token"

# ---- Cron protection (cron-job.org passes ?key=THIS) ----
# Generate with: openssl rand -hex 24
CRON_SECRET="replace-me"

# ---- Admin (comma-separated emails allowed at /admin/lineups) ----
ADMIN_EMAILS="you@example.com"

# ---- Public app URL (used for share links, OG cards, invite links) ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
